# --- Required ---
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# --- Security (recommended for production) ---
# SECRET_KEY is auto-generated if left blank; set a fixed one for production
SECRET_KEY=
# Set to "true" when using HTTPS (Cloudflare, etc.)
SESSION_COOKIE_SECURE=false

# --- Server ---
# Set to "true" to enable Flask debug mode (dev only!)
FLASK_DEBUG=false
# Bind address (0.0.0.0 for public, 127.0.0.1 for local-only)
FLASK_HOST=127.0.0.1
FLASK_PORT=5000
